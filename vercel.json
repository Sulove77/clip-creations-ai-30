{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build:vercel",
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/placeholder.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
